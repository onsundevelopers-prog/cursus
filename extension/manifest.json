{
  "manifest_version": 3,
  "name": "Cursus AI Job Autofill",
  "version": "1.0.0",
  "description": "AI-powered job application autofill and career assistant.",
  "permissions": ["activeTab", "storage", "scripting"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.workday.com/*", "*://*.lever.co/*", "*://*.greenhouse.io/*", "*://*.linkedin.com/*"],
      "js": ["popup.js"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
